	measure 'Top Channel Name' =
			
			VAR WebPct = [Web Purchase %]
			VAR StorePct = [Store Purchase %]
			VAR CatalogPct = [Catalog Purchase %]
			
			RETURN
			SWITCH(
			    TRUE(),
			    WebPct >= StorePct && WebPct >= CatalogPct, "Web",
			    StorePct >= WebPct && StorePct >= CatalogPct, "Store",
			    "Catalog"
			)
		lineageTag: 646ffa16-ac8a-496b-952e-97c81f3b0b19

	measure 'Purchases by Channel' =
			
			SWITCH(
			    SELECTEDVALUE('Channel Table'[Channel]),
			    "Web", SUM(FactCustomerMetrics[NumWebPurchases]),
			    "Store", SUM(FactCustomerMetrics[NumStorePurchases]),
			    "Catalog", SUM(FactCustomerMetrics[NumCatalogPurchases]),
			    "Deals", SUM(FactCustomerMetrics[NumDealsPurchases])
			)
		formatString: 0
		lineageTag: 2754c30e-1102-4f3d-94c2-884946cb1b9b

	measure 'Revenue by Channel' =
			
			SWITCH(
			    SELECTEDVALUE('Channel Table'[Channel]),
			    "Web", [Total Revenue] * [Web Purchase %],
			    "Store", [Total Revenue] * [Store Purchase %],
			    "Catalog", [Total Revenue] * [Catalog Purchase %],
			    "Deals", [Total Revenue] * [Deals Purchase %]
			)
		formatString: "S/"\ #,0.00;-"S/"\ #,0.00;"S/"\ #,0.00
