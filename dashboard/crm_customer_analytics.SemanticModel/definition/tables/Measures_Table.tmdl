table Measures_Table
	lineageTag: 052d9a09-08b3-4bce-961b-c937b1ec53cf

	measure 'Total Customers' = DISTINCTCOUNT(FactCustomerMetrics[ID])
		formatString: #,0
		displayFolder: KPIs\Customer KPIs
		lineageTag: 4a60286f-e048-437f-8117-14906c518063

	measure 'Avg Customer Income' = AVERAGE(FactCustomerMetrics[Income])
		formatString: #,0.00
		displayFolder: KPIs\Customer KPIs
		lineageTag: 9b5914a0-37eb-44ed-b4b0-ff3e90104971

	measure 'Avg Customer Age' = AVERAGE(DimCustomer[Age])
		formatString: 0.00
		displayFolder: KPIs\Customer KPIs
		lineageTag: 9a2846c0-05da-48a8-9d4c-639326ea165a

	measure 'Avg Recency' = AVERAGE(FactCustomerMetrics[Recency])
		formatString: 0.00
		displayFolder: KPIs\Customer KPIs
		lineageTag: 983a2658-e481-4184-8fe2-d6fc79488e4f

	measure 'Customers With Children' =
			
			CALCULATE(
			    COUNTROWS(FactCustomerMetrics),
			    FactCustomerMetrics[Total_Children]> 0
			)
		formatString: #,0
		displayFolder: KPIs\Customer KPIs
		lineageTag: 6f366abc-9e93-4f4d-beee-6ba85150e7f9

	measure 'Total Revenue' = SUM(FactCustomerMetrics[Total_Spending])
		formatString: "S/"\ #,0.00;-"S/"\ #,0.00;"S/"\ #,0.00
		displayFolder: KPIs\Revenue KPIs
		lineageTag: c91166f0-b60a-4003-a879-ae72e73c6913

		annotation PBI_FormatHint = {"currencyCulture":"es-PE"}

	measure 'Avg Purchase Value' =
			
			DIVIDE(
			    [Total Revenue],
			    [Total Purchases],
			    0
			)
		formatString: "S/"\ #,0.00;-"S/"\ #,0.00;"S/"\ #,0.00
		displayFolder: KPIs\Revenue KPIs
		lineageTag: 8f1ebe62-01c0-4490-a44a-16735ed0ef8e

		annotation PBI_FormatHint = {"currencyCulture":"es-PE"}

	measure 'Revenue Engaged Customers' =
			
			CALCULATE(
			    [Total Revenue],
			    FactCustomerMetrics[Engagement_Score] > 0
			)
		formatString: "S/"\ #,0.00;-"S/"\ #,0.00;"S/"\ #,0.00
		displayFolder: KPIs\Revenue KPIs
		lineageTag: 21151e81-152a-435b-9e17-9ea478d84f58

		annotation PBI_FormatHint = {"currencyCulture":"es-PE"}

	measure 'Revenue Wines' = SUM(FactCustomerMetrics[MntWines])
