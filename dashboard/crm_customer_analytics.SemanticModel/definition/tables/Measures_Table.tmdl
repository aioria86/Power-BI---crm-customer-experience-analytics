	measure 'Catalog Purchases' = SUM(FactCustomerMetrics[NumCatalogPurchases])
		formatString: #,0
		displayFolder: KPIs\Purchase Behavior KPIs
		lineageTag: 5950b3fc-842b-42ad-a75e-f35a191d2ae4

	measure 'Campaign Responses' = SUM(FactCustomerMetrics[Response])
		formatString: #,0
		displayFolder: KPIs\Marketing Campaign KPIs
		lineageTag: 470dc576-d7b9-4732-9f17-f3f8ddaef74c

	measure 'Campaign Conversion Rate' =
			
			DIVIDE(
			    [Campaign Responses],
			    [Total Customers]
			    )
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		displayFolder: KPIs\Marketing Campaign KPIs
		lineageTag: 9bd9b47e-7137-482d-90a9-f3f4f46c3018

	measure 'Total Campaign Accepted' = SUM(FactCustomerMetrics[TotalCampaignAccepted])
		formatString: #,0
		displayFolder: KPIs\Marketing Campaign KPIs
		lineageTag: a04bc006-2707-414a-b4e9-955d43a59e21

	measure 'Avg Campaign Accepted' = AVERAGE(FactCustomerMetrics[TotalCampaignAccepted])
		displayFolder: KPIs\Marketing Campaign KPIs
		lineageTag: 9239dd31-c8fd-4a61-9b2b-29e8c56b7c6c

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Revenue Campaign Responders' =
			
			CALCULATE(
			    [Total Revenue],
			    FactCustomerMetrics[Response] = 1
			)
		formatString: "S/"\ #,0.00;-"S/"\ #,0.00;"S/"\ #,0.00
		displayFolder: KPIs\Marketing Campaign KPIs
		lineageTag: 7e44a5ac-db5c-4b3b-a528-d6b0986a57f7

		annotation PBI_FormatHint = {"currencyCulture":"es-PE"}

	measure 'Avg Engagement' = AVERAGE(FactCustomerMetrics[Engagement_Score])
		displayFolder: KPIs\Engagement KPIs
		lineageTag: 4fa8c169-7199-4656-bdc9-06d48140af78

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'High Engagement Customers' =
			
			CALCULATE(
			    [Total Customers],
			    FactCustomerMetrics[Engagement_Score] >= 11
			)
		formatString: #,0
		displayFolder: KPIs\Engagement KPIs
		lineageTag: 29f18464-726a-4103-8169-6d2d6e39faf4

	measure 'Active Customers' =
			
			CALCULATE(
			    [Total Customers],
			    FactCustomerMetrics[Recency] <= 30
			)
		formatString: #,0
		displayFolder: KPIs\Retention KPIs
		lineageTag: 4006b34a-8cc1-41de-86ac-2eb8c5e188c9

	measure 'At Risk Customers' =
			
			CALCULATE(
			    [Total Customers],
			    FactCustomerMetrics[Recency] > 90
			)
		formatString: #,0
		displayFolder: KPIs\Retention KPIs
		lineageTag: 245500a3-558a-4015-8aae-05f297a99f45

	measure 'Estimated CLV' = [Avg Purchase Value] * [Avg Purchases Customer]
		formatString: "S/"\ #,0.###############;-"S/"\ #,0.###############;"S/"\ #,0.###############
		displayFolder: KPIs\Retention KPIs
		lineageTag: f07ad5ed-7956-445b-a845-443a3aa921ab

		annotation PBI_FormatHint = {"currencyCulture":"es-PE"}

	measure 'Total Customers Prev Month' =
			
			CALCULATE(
			    [Total Customers],
			    DATEADD(
			        DimDate[Date],
			        -1,
			        MONTH
			    ))
		formatString: #,0
		lineageTag: 39fefa91-79df-43c0-bdb6-1956f2509fbb

	measure 'Total Customers Variance' = [Total Customers] - [Total Customers Prev Month]
		formatString: 0
		lineageTag: ee979542-fe23-4525-940e-3c0cd1833921

	measure '% Customer Growth' =
			
			DIVIDE(
			    [Total Customers] - [Total Customers Prev Month],
			    [Total Customers Prev Month],
			    0
			)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: 2a4157e5-a1c7-4aa4-bbfc-9737ac2bd697

	measure 'New Customers' =
			
			CALCULATE(
			    [Total Customers],
			    DATESINPERIOD(
			        DimDate[Date],
			        MAX(DimDate[Date]),
			        -1,
			        MONTH
			    )
			)
		formatString: #,0
		lineageTag: d50d9ac6-4e90-4116-8dae-06f47291e9a3

	measure 'Total Revenue Prev Month' =
			
			CALCULATE(
			    [Total Revenue],
			    DATEADD(
			        DimDate[Date],
			        -1,
			        MONTH
			    )
			)
		formatString: "S/"\ #,0.00;-"S/"\ #,0.00;"S/"\ #,0.00
		lineageTag: 6cb719a8-67d9-4152-a6b2-f137ce5e96cf

		annotation PBI_FormatHint = {"currencyCulture":"es-PE"}

	measure 'Total Revenue Variance' = [Total Revenue] - [Total Revenue Prev Month]
		formatString: "S/"\ #,0.00;-"S/"\ #,0.00;"S/"\ #,0.00
		lineageTag: a62d6e78-21c7-4c60-9bf6-4a5fc4b2836a

		annotation PBI_FormatHint = {"currencyCulture":"es-PE"}

	measure '% Revenue Growth' =
			
			DIVIDE(
			    [Total Revenue] - [Total Revenue Prev Month],
			    [Total Revenue Prev Month],
			    0
			)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: 703cc824-3339-41da-b714-bf986e4dbaf5

	measure ARPC =
			
			DIVIDE(
			    [Total Revenue],
			    [Total Customers]
			)
		formatString: "S/"\ #,0.00;-"S/"\ #,0.00;"S/"\ #,0.00
		lineageTag: 1d97d10c-49fd-4a2c-bbb8-49071ee03ebd

		annotation PBI_FormatHint = {"currencyCulture":"es-PE"}

	measure 'High Value Revenue' =
			
			CALCULATE(
			    [Total Revenue],
			    FactCustomerMetrics[Total_Spending] >
			    AVERAGE(FactCustomerMetrics[Total_Spending])
			)
		formatString: "S/"\ #,0.00;-"S/"\ #,0.00;"S/"\ #,0.00
		lineageTag: 8b558a1b-11b6-488f-9d78-1ee870d73d34

		annotation PBI_FormatHint = {"currencyCulture":"es-PE"}

	measure '% Revenue High Value' =
			
			DIVIDE(
			    [High Value Revenue],
			    [Total Revenue],
			    0
			)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: bac8fcba-cd38-4df9-9d47-306666078963

	measure 'Campaign Conversion Rate Prev Month' =
			
			CALCULATE(
			    [Campaign Conversion Rate],
			    DATEADD(
			        DimDate[Date],
			        -1,
			        MONTH
			    )
			)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: 3607f474-1606-4a8a-90bd-b258d4f64f36

	measure 'Campaign Conversion Rate Variance' = [Campaign Conversion Rate] - [Campaign Conversion Rate Prev Month]
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: a9f776f1-eed0-40a1-a35a-58e37af2324e

	measure '% Campaign Conversion Rate Growth' =
			
			DIVIDE(
			    [Campaign Conversion Rate] - [Campaign Conversion Rate Prev Month],
			    [Campaign Conversion Rate Prev Month],
			    0
			)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: 177a928e-e66c-4a77-b55c-541b86d3935b

	measure 'Revenue per Response' =
			
			DIVIDE(
			    [Total Revenue],
			    [Campaign Responses]
			)
		formatString: "S/"\ #,0.00;-"S/"\ #,0.00;"S/"\ #,0.00
		lineageTag: d56bc92b-86e7-446a-8d9e-7329a9b7b19a

		annotation PBI_FormatHint = {"currencyCulture":"es-PE"}

	measure 'Revenue Selected Category' =
			
			SWITCH(
			    SELECTEDVALUE('Product Category Table'[Category]),
			    "Wines", [Revenue Wines],
			    "Meat", [Revenue Meat],
			    "Fish", [Revenue Fish],
			    "Fruits", [Revenue Fruits],
			    "Sweets", [Revenue Sweets],
			    "Gold", [Revenue Gold]
			)
		formatString: 0
		lineageTag: 97d8149f-6816-4f73-a098-a54acc42a960

	measure 'Avg Customer Income Prev Month' =
			
			CALCULATE(
			    [Avg Customer Income],
			    DATEADD(
			        DimDate[Date],
			        -1,
			        MONTH
			    )
			)
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: a6243561-1dde-4673-bcd1-cf4b0a156fb4

		annotation PBI_FormatHint = {"currencyCulture":"es-US"}

	measure 'Median Income' = MEDIAN(FactCustomerMetrics[Income])
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: 7f95eaec-1c34-43b9-a185-314884a1c76d

		annotation PBI_FormatHint = {"currencyCulture":"es-US"}

	measure '% High Income' =
			
			DIVIDE(
			    CALCULATE(
			        DISTINCTCOUNT(FactCustomerMetrics[ID]),
			        FactCustomerMetrics[Income] >= 80000
			    ),
			    [Total Customers]
			)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: 2835beef-9acb-4fe8-af6c-c85d000307cf

	measure 'Avg Customer Income Variance' = [Avg Customer Income] - [Avg Customer Income Prev Month]
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: 3e6fda3d-a814-45eb-86af-b2ffe403e142

		annotation PBI_FormatHint = {"currencyCulture":"es-US"}

	measure '% Avg Customer Income Growth' =
			
			DIVIDE(
			    [Avg Customer Income] - [Avg Customer Income Prev Month],
			    [Avg Customer Income Prev Month],
			    0
			)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: 9817cadc-7b9c-413b-92e5-2eb749617351

	measure 'Avg Customer Age Previous Month' =
			
			CALCULATE(
			    [Avg Customer Age],
			    DATEADD(
			        DimDate[Date],
			        -1,
			        MONTH
			    )
			)
		formatString: 0.00
		lineageTag: c826e9e9-1954-48e2-8184-e9dafe19fdc7

	measure 'Avg Customer Age Variance' = [Avg Customer Age] - [Avg Customer Age Previous Month]
		formatString: 0.00
		lineageTag: 68f9e6d7-6a54-4d78-8375-e012f89f1a7b

	measure '% Avg Customer Age Growth' =
			
			DIVIDE(
			    [Avg Customer Age] - [Avg Customer Age Previous Month],
			    [Avg Customer Age Previous Month],
			    0
			)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: 53f7e792-e44a-4749-8f39-e0e79b5d5e77

	measure 'Median Age' = MEDIAN(DimCustomer[Age])
		lineageTag: fadc9310-323e-43d0-93cb-246ad051d1e6

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '% Core Age (30-55)' =
			
			DIVIDE(
			    CALCULATE(
			        DISTINCTCOUNT(FactCustomerMetrics[ID]),
			        DimCustomer[Age] >= 30 &&
			        DimCustomer[Age] <= 55
			    ),
			    [Total Customers]
			)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: ff150cb9-61b7-4dc3-bdb7-d7f924b07ee8

	measure 'ARPC Prev Month' =
			
			CALCULATE(
			    [ARPC],
			    DATEADD(
			        DimDate[Date],
			        -1,
			        MONTH
			    )
			)
		formatString: "S/"\ #,0.00;-"S/"\ #,0.00;"S/"\ #,0.00
		lineageTag: 050ff77b-6971-49f4-b661-fe1008a65cc5

		annotation PBI_FormatHint = {"currencyCulture":"es-PE"}

	measure 'ARPC Variance' = [ARPC] - [ARPC Prev Month]
		formatString: "S/"\ #,0.00;-"S/"\ #,0.00;"S/"\ #,0.00
		lineageTag: b824ede0-9826-4225-9a56-2d9a4a60b4a6

		annotation PBI_FormatHint = {"currencyCulture":"es-PE"}

	measure '% ARPC Growth' =
			
			DIVIDE(
			    [ARPC] - [ARPC Prev Month],
			    [ARPC Prev Month],
			    0
			)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: cc65f493-e994-40cb-b628-4878e9904fa3

	measure '% High Value Customers' =
			
			DIVIDE(
			    CALCULATE(
			        DISTINCTCOUNT(FactCustomerMetrics[ID]),
			        FactCustomerMetrics[Total_Spending] > 1000
			    ),
			    [Total Customers]
			)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: 9261db58-32a1-48ba-a5bc-34362bdcda59

	measure '% Top Segment Revenue' =
			
			DIVIDE(
			    CALCULATE(
			        [Total Revenue],
			        DimCustomer[Age_segment] = "Mature"
			    ),
			    [Total Revenue]
			)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: 27c2844f-bb3c-463e-9052-daa6c3d856ad

	measure 'Total Income' = SUM(FactCustomerMetrics[Income])
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: 792366bf-1ec2-480c-a03d-4bd577dfa02c

		annotation PBI_FormatHint = {"currencyCulture":"es-US"}

	measure 'Avg Spending' = AVERAGE(FactCustomerMetrics[Total_Spending])
		formatString: "S/"\ #,0.00;-"S/"\ #,0.00;"S/"\ #,0.00
		lineageTag: 0b9091fb-7da8-4e38-9700-17e68baa95fb

		annotation PBI_FormatHint = {"currencyCulture":"es-PE"}

	measure 'Top Product Revenue %' =
			
			DIVIDE(
			    MAXX(
			        VALUES('Product Category Table'[Category]),
			        [Revenue Selected Category]
			    ),
			    [Total Revenue]
			)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: f851b2e4-19b8-4b07-bf58-d5e0e4e7470e

	measure 'Avg Purchase Value Prev Month' =
			
			CALCULATE(
			    [Avg Purchase Value],
			    DATEADD(
			        DimDate[Date],
			        -1,
			        MONTH
			    )
			)
		formatString: "S/"\ #,0.00;-"S/"\ #,0.00;"S/"\ #,0.00
		lineageTag: 8b6e25f2-9185-46db-a8c2-adfe3ee47330

		annotation PBI_FormatHint = {"currencyCulture":"es-PE"}

	measure 'Avg Purchase Value Variance' = [Avg Purchase Value] - [Avg Purchase Value Prev Month]
		formatString: "S/"\ #,0.00;-"S/"\ #,0.00;"S/"\ #,0.00
		lineageTag: f7722c7c-9832-4dda-9601-0da89be20384

		annotation PBI_FormatHint = {"currencyCulture":"es-PE"}

	measure '% Avg Purchase Value Growth' =
			
			DIVIDE(
			    [Avg Purchase Value] - [Avg Purchase Value Prev Month],
			    [Avg Purchase Value Prev Month],
			    0
			)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: 1363bd79-0b13-4bfd-b55b-1e165fe24821

	measure 'High Value Transactions %' =
			
			DIVIDE(
			    CALCULATE(
			        COUNTROWS(FactCustomerMetrics),
			        FactCustomerMetrics[Total_Spending] > 500
			    ),
			    COUNTROWS(FactCustomerMetrics)
			)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: b3caa458-0395-46d9-9a81-bab925896675

	measure 'Revenue Concentration %' =
			
			VAR MaxRevenue =
			    MAXX(
			        {
			            [Revenue Wines],
			            [Revenue Meat],
			            [Revenue Gold],
			            [Revenue Fish],
			            [Revenue Fruits],
			            [Revenue Sweets]
			        },
			        [Value]
			    )
			RETURN
			DIVIDE(
			    MaxRevenue,
			    [Total Revenue]
			)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: 0a20d7f5-9cfe-46b8-8453-e18cac813adc

	measure 'Active Categories' =
			
			CALCULATE(
			    COUNTROWS(
			        FILTER(
			            {
			                [Revenue Wines],
			                [Revenue Meat],
			                [Revenue Gold],
			                [Revenue Fish],
			                [Revenue Fruits],
			                [Revenue Sweets]
			            },
			            [Value] > 0
			        )
			    )
			)
		formatString: 0
		lineageTag: af521085-f2ea-4e76-ace0-77a75f4dc38a

	measure 'Revenue Concentration % Prev Month' =
			
			CALCULATE(
			    [Revenue Concentration %],
			    DATEADD(
			        DimDate[Date],
			        -1,
			        MONTH
			    )
			)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: d3d097f6-ee1d-4ce8-a354-2a82cf5f3b4e

	measure 'Revenue Concentration % Variance' = [Revenue Concentration %] - [Revenue Concentration % Prev Month]
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: 89d84ad9-1ccf-4dfe-8329-59902c721b14

	measure '% Revenue Concentration Growth' =
			
			DIVIDE(
			    [Revenue Concentration %] - [Revenue Concentration % Prev Month],
			    [Revenue Concentration % Prev Month],
			    0
			)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: db024b32-a1c9-44c9-bbd1-649155768fc7

	measure 'Top Product Revenue' =
			
			MAXX(
			    {
			        [Revenue Wines],
			        [Revenue Meat],
			        [Revenue Gold],
