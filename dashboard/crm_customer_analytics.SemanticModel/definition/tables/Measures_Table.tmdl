		displayFolder: KPIs\Purchase Behavior KPIs
		lineageTag: 71e30ce2-f1b6-4a31-89f0-500fbae3fc7a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Web Purchases' = SUM(FactCustomerMetrics[NumWebPurchases])
